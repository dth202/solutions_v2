<?php
    $incidentDetails = $sqlTool->getIncidentDetails($incident_id);
    
    echo '<h2>Incident Details</h2>';
    echo '<div class="shadow" style="margin:20px;">';
       if ($incidentDetails['completed_date'] == '' || !isset($incidentDetails['completed_date']) ) { 
			    $status = 'class="open"'; 
          $completed_date = 'In Progress';
		    } else { 
			    $status = 'class="closed"'; 
          $completed_date = $sqlTool->convertDate2String($incidentDetails['completed_date']);
		    }
      echo '<a href="incident.php?incident_id='.$incident_id.'">'.$sqlTool->convertDate2String($incidentDetails[created_date]).'</a> - ';
      echo $completed_date;
      echo '<br /><h4><a href="company.php?company_id='.$incidentDetails['company_id'].'">' . $incidentDetails['company_name'] . '</a></h4>';
    echo '</div>';
    
 
?>